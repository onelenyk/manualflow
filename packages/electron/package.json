{
  "name": "@maestro-recorder/electron",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for ManualFlow — wraps the existing server + dashboard.",
  "main": "dist/main.js",
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "start": "npm run build:ts && cross-env MANUALFLOW_DEV=1 electron .",
    "package": "npm run build:ts && electron-forge package",
    "make": "npm run build:ts && electron-forge make"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-deb": "^7.5.0",
    "@electron-forge/maker-dmg": "^7.5.0",
    "@electron-forge/maker-squirrel": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "@types/node": "^22.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "typescript": "^5.6.0"
  }
}
