{
  "private": true,
  "workspaces": [
    "packages/*",
    "dashboard/frontend"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p packages/shared/tsconfig.json --noEmit && tsc -p packages/server/tsconfig.json --noEmit && tsc -p packages/electron/tsconfig.json --noEmit",
    "electron:start": "npm run -w packages/electron start",
    "electron:package": "npm run -w packages/electron package",
    "electron:make": "npm run -w packages/electron make"
  },
  "devDependencies": {
    "vitest": "^4.1.3"
  }
}
